<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="rootContainer" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="carcassonne.View.LoginView">
   <children>
      <VBox alignment="BOTTOM_CENTER" fillWidth="false" prefHeight="200.0" prefWidth="400.0">
         <children>
            <Label fx:id="errorLabel" textFill="#fc0f0f">
               <VBox.margin>
                  <Insets bottom="10.0" />
               </VBox.margin>
            </Label>
            <TextField fx:id="userNameField" promptText="Username" />
            <TextField fx:id="passWordField" promptText="Password" />
         </children>
      </VBox>
      <StackPane>
         <children>
            <Button fx:id="btnLogin" mnemonicParsing="false" onAction="#onLogin" text="Login" />
         </children>
         <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
         </padding>
      </StackPane>
      <StackPane alignment="TOP_CENTER" prefHeight="150.0" prefWidth="200.0">
         <children>
            <Button fx:id="btnBack" mnemonicParsing="false" onAction="#onBack" text="Back" />
         </children>
      </StackPane>
   </children>
</VBox>
